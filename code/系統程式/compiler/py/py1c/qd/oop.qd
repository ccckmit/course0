CLASS               BankAccount                             _                _                 ; class BankAccount
FUNCTION            _                                       _                __init__          ; function __init__
ENTER_SCOPE         _                                       _                _               
PARAM               _                                       _                self            
PARAM               _                                       _                owner           
PARAM               _                                       _                balance         
