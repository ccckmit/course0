LOAD_NAME           self                                    _                t28               ; load self
LOAD_ATTR           t28                                     balance          t29               ; getattr balance
LOAD_NAME           amount                                  _                t30               ; load amount
CMP_GE              t29                                     t30              t31             
BRANCH_IF_FALSE     t31                                     _                L_else0           ; if not test, go to else
LOAD_NAME           self                                    _                t32               ; load self
LOAD_ATTR           t32                                     balance          t33               ; getattr balance
LOAD_NAME           amount                                  _                t34               ; load amount
SUB                 t33                                     t34              t35             
